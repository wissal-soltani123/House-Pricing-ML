# ------------------------------------------------------------
# ===============================
# 7. Export cleaned test dataset
# ===============================
write.csv(test, "C:/Users/guerf/OneDrive/Documenti/Bureau/House Pricing R/data/Cleaned/test_clean.csv", row.names = FALSE)
